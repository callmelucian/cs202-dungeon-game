@startuml Echoes_of_the_Ashen_Vault_Architecture

' --- Configuration ---
skinparam class {
    BackgroundColor White
    ArrowColor DeepSkyBlue
    BorderColor DarkSlateGray
}
skinparam stereotypeCBackgroundColor LightGreen
skinparam packageStyle rectangle

' ============================================================
' PACKAGE: Core Game Loop & State Management
' ============================================================
package "Core" {

    class Game << (S,#FF7F24) Singleton >> {
        - renderWindow : sf::RenderWindow
        - stateManager : StateManager
        - Game()
        + {static} getInstance() : Game&
        + runMainLoop() : void
        + getWindow() : sf::RenderWindow&
    }

    class StateManager {
        - states : std::stack<std::unique_ptr<GameState>>
        + pushState(state : std::unique_ptr<GameState>) : void
        + popState() : void
        + changeState(state : std::unique_ptr<GameState>) : void
        + update(dt : float) : void
        + draw() : void
        + handleEvents(event : sf::Event&) : void
    }

    abstract class GameState {
        # stateManager : StateManager&
        + {abstract} update(dt : float) : void
        + {abstract} draw(window : sf::RenderWindow&) : void
        + {abstract} handleEvents(event : sf::Event&) : void
    }

    class MainMenuState extends GameState
    class CharacterSelectState extends GameState
    class GameplayState extends GameState
    class PauseState extends GameState
    class GameOverState extends GameState
    class SettingState extends GameState

    Game o-- StateManager
    StateManager *-- GameState
}

' ============================================================
' PACKAGE: Global Settings
' ============================================================
package "Global Settings" {

    class SettingManager << (S,#FF7F24) Singleton >> {
        - musicVolume : float
        - sfxVolume : float
        - difficulty : std::string
        - keyBindings : std::unordered_map<std::string, sf::Keyboard::Scancode>
        - SettingManager()
        + {static} getInstance() : SettingManager&
        + loadSettings(filepath : std::string) : bool
        + saveSettings(filepath : std::string) : bool
        + getMusicVolume() : float
        + setMusicVolume(volume : float) : void
        + getSfxVolume() : float
        + setSfxVolume(volume : float) : void
        + getDifficulty() : std::string
        + setDifficulty(diff : std::string) : void
        + getKeyBinding(action : std::string) : sf::Keyboard::Scancode
        + setKeyBinding(action : std::string, scancode : sf::Keyboard::Scancode) : void
    }

    class AssetManager << (S,#FF7F24) Singleton >> {
        - textures : std::unordered_map<std::string, sf::Texture>
        - fonts : std::unordered_map<std::string, sf::Font>
        - AssetManager()
        + {static} getInstance() : AssetManager&
        + loadTexture(name : std::string, filepath : std::string) : bool
        + getTexture(name : std::string) : const sf::Texture&
        + loadFont(name : std::string, filepath : std::string) : bool
        + getFont(name : std::string) : const sf::Font&
    }

    class AnimationManager << (S,#FF7F24) Singleton >> {
        - animationSets : std::unordered_map<std::string, AnimationSet>
        - AnimationManager()
        + {static} getInstance() : AnimationManager&
        + loadAnimationSet(character : std::string, filepath : std::string) : bool
        + getAnimationSet(character : std::string) : const AnimationSet&
    }

    class SoundManager << (S,#FF7F24) Singleton >> {
        - soundBuffers : std::unordered_map<std::string, sf::SoundBuffer>
        - music : sf::Music
        - SoundManager()
        + {static} getInstance() : SoundManager&
        + loadSound(name : std::string, filepath : std::string) : bool
        + playSound(name : std::string) : void
        + playMusic(filepath : std::string, loop : bool) : void
        + stopMusic() : void
    }

    class SaveLoadManager << (S,#FF7F24) Singleton >> {
        - SaveLoadManager()
        + {static} getInstance() : SaveLoadManager&
        + saveGame(filepath : std::string, player : const Player&, levelNum : int, chamberNum : int, echoes : const std::vector<Echo*>&) : bool
        + loadGame(filepath : std::string, player : Player&, levelNum : int&, chamberNum : int&, echoes : std::vector<Echo*>&) : bool
    }

    class ColorPalette <<struct>> {
        + primary : sf::Color
        + secondary : sf::Color
        + background : sf::Color
        + text : sf::Color
        + accent : sf::Color
        + success : sf::Color
        + warning : sf::Color
        + disabled : sf::Color
    }

    interface ColorPaletteObserver {
        + {abstract} onColorPaletteChanged(newPalette : const ColorPalette&) : void
    }

    class ColorPaletteManager << (S,#FF7F24) Singleton >> {
        - currentPalette : ColorPalette
        - ColorPaletteManager()
        + {static} getInstance() : ColorPaletteManager&
        + getPalette() : const ColorPalette&
        + setPalette(palette : const ColorPalette&) : void
        + addObserver(observer : ColorPaletteObserver*) : void
        + removeObserver(observer : ColorPaletteObserver*) : void
    }

    ColorPaletteManager o-- ColorPaletteObserver
    ColorPaletteManager *-- ColorPalette

    class TileManager << (S,#FF7F24) Singleton >> {
        - tilesById : std::unordered_map<int, TileData>
        - nameToId : std::unordered_map<std::string, int>
        - tileSize : sf::Vector2i
        - TileManager()
        + {static} getInstance() : TileManager&
        + loadTileMap(filepath : std::string) : bool
        + getTileRect(id : int) : sf::IntRect
        + getTileRect(name : std::string) : sf::IntRect
        + getTileId(name : std::string) : int
        + getTileSize() : sf::Vector2i
    }
}

' ============================================================
' PACKAGE: UI Framework
' ============================================================
package "UI Framework" {

    abstract class Component << ColorPaletteObserver >> {
        # parent : Component*
        # position : sf::Vector2f
        # size : sf::Vector2f
        + {abstract} draw(target : sf::RenderTarget&) : void
        + {abstract} handleEvent(event : const sf::Event&) : void
        + {abstract} update(dt : float) : void
        + {abstract} onColorPaletteChanged(palette : const ColorPalette&) : void
        + {abstract} computeSize(availableSize : sf::Vector2f) : void
        + {abstract} setPosition(pos : sf::Vector2f) : void
    }

    class Text {
        - text : sf::Text
        - fontKey : std::string
        + Text(fontKey : std::string_view, characterSize : unsigned int)
        + setString(str : const sf::String&) : void
        + setCharacterSize(size : unsigned int) : void
        + setFillColor(color : const sf::Color&) : void
        + getUnderlyingText() : const sf::Text&
    }

    class Container {
        # children : std::vector<std::unique_ptr<Component>>
        # isRootNode : bool
        + addChild(child : std::unique_ptr<Component>) : Component*
        + createChild<T>(args...) : T*
        + getChildren() : const std::vector<std::unique_ptr<Component>>&
        + setPadding(top : float, bottom : float, left : float, right : float) : void
    }

    class FlexBox<Axis> {
        - spacing : float
        - distribution : Distribution
        - overflow : Overflow
    }

    class HorizontalBox << typedef >>
    class VerticalBox << typedef >>

    class Button {
        - state : ButtonState
        - label : std::unique_ptr<Text>
        - backgroundShape : sf::RectangleShape
        - onClickCallback : std::function<void()>
        - onPressedCallback : std::function<void()>
        + setOnClick(callback : std::function<void()>) : void
        + setOnPressed(callback : std::function<void()>) : void
        + setLabelText(labelText : const sf::String&) : void
    }

    class Slider {
        - minValue : float
        - maxValue : float
        - value : float
        - dragging : bool
        - dragOffset : float
        - trackShape : sf::RectangleShape
        - thumbShape : sf::RectangleShape
        - onValueChangedCallback : std::function<void(float)>
        + getValue() : float
        + setValue(newValue : float) : void
        + setOnValueChanged(callback : std::function<void(float)>) : void
    }

    class TextInput {
        - textDisplay : std::unique_ptr<Text>
        - backgroundShape : sf::RectangleShape
        - cursorShape : sf::RectangleShape
        - cursorIndex : std::uint32_t
        - hasFocus : bool
        - blinkTimer : float
        - blinkDuration : float
        - cursorVisible : bool
        - onTextChangedCallback : std::function<void(const sf::String&)>
        - onEnterPressedCallback : std::function<void()>
        + setTextString(str : const sf::String&) : void
        + getTextString() : sf::String
        + setKeyboardFocus(focus : bool) : void
    }

    Component ..|> ColorPaletteObserver
    Container --|> Component
    FlexBox --|> Container
    HorizontalBox --|> FlexBox
    VerticalBox --|> FlexBox
    Button --|> Component
    Slider --|> Component
    TextInput --|> Component
}

' ============================================================
' PACKAGE: Entities (Merged Entities & Enemies)
' ============================================================
package "Entities" {

    ' ---- Shared stat model (used by Player forms, specials AND fixed enemy stats) ----
    class Stats <<struct>> {
        + hp : float
        + maxHp : float
        + damage : float
        + speed : float
        + defense : float
    }

    class StatModifier <<struct>> {
        + hpMultiplier : float
        + damageMultiplier : float
        + speedMultiplier : float
        + applyTo(base : const Stats&) : Stats
    }

    ' ---- Visual layer decoupled from logic via Observer ----
    interface CharacterObserver {
        + {abstract} onStateChanged(character : const Character&, visualKey : std::string) : void
        + {abstract} onDamaged(character : const Character&, amount : float) : void
        + {abstract} onDefeated(character : const Character&) : void
    }

    class AnimationFrame <<struct>> {
        + frameRegion : sf::IntRect
        + duration : float
    }

    class Animation {
        - frames : std::vector<AnimationFrame>
        - checkpoints : std::vector<double>
        - looping : bool
        + Animation(frames : std::vector<AnimationFrame>, looping : bool)
        + getFrame(elapsed : float) : const AnimationFrame&
        + isFinished(elapsed : float) : bool
    }

    class AnimationSet <<struct>> {
        + textureKey : std::string
        + animations : std::unordered_map<std::string, Animation>
        + addAnimation(animationKey : std::string, animation : Animation) : void
        + getAnimation(animationKey : std::string) : const Animation&
    }

    Animation *-- AnimationFrame
    AnimationSet *-- Animation

    class CharacterAnimator << Observer >> {
        - sprite : std::unique_ptr<sf::Sprite>
        - characterKey : std::string
        - currentAnimationKey : std::string
        - hitFlashTimer : float
        - currentAnimationElapsed : float
        + CharacterAnimator(characterKey : std::string)
        + onStateChanged(character : const Character&, visualKey : std::string) : void
        + onDamaged(character : const Character&, amount : float) : void
        + onDefeated(character : const Character&) : void
        + update(dt : float) : void
        + draw(window : sf::RenderWindow&) : void
    }
    CharacterAnimator ..|> CharacterObserver

    abstract class Character {
        # position : sf::Vector2f
        # velocity : sf::Vector2f
        # baseStats : Stats
        # statusEffects : std::vector<std::unique_ptr<StatusEffect>>
        # observers : std::vector<CharacterObserver*>
        # animator : std::unique_ptr<CharacterAnimator>
        + {abstract} update(dt : float) : void
        + draw(window : sf::RenderWindow&) : void
        + getEffectiveStats() : Stats
        + takeDamage(rawAmount : float) : void
        # calculateMitigatedDamage(rawAmount : float) : float
        + isAlive() : bool
        + applyStatusEffect(effect : std::unique_ptr<StatusEffect>) : void
        + addObserver(observer : CharacterObserver*) : void
        + removeObserver(observer : CharacterObserver*) : void
        # notifyStateChanged(visualKey : std::string) : void
        + getPosition() : sf::Vector2f
        + getHp() : float
    }

    Character *-- Stats
    Character o-- CharacterObserver
    Character *-- CharacterAnimator

    abstract class StatusEffect {
        # duration : float
        # timer : float
        + {abstract} apply(character : Character&) : void
        + {abstract} remove(character : Character&) : void
        + update(dt : float, character : Character&) : bool
    }

    class BurnedEffect extends StatusEffect {
        - damagePerTick : float
    }
    class ParalyzedEffect extends StatusEffect {
        - missChance : float
    }
    class SlowedEffect extends StatusEffect {
        - modifier : StatModifier
    }

    Character *-- StatusEffect
    StatusEffect ..> StatModifier : uses

    ' ---- Player combat state machine (State pattern) ----
    interface PlayerCombatState << State >> {
        + {abstract} onEnter(player : Player&) : void
        + {abstract} onExit(player : Player&) : void
        + {abstract} update(player : Player&, dt : float) : void
        + {abstract} onAttack(player : Player&, targetDir : sf::Vector2f, chamber : Chamber&) : void
        + {abstract} modifyOutgoingDamage(baseAmount : float) : float
        + {abstract} modifyIncomingDamage(player : Player&, amount : float) : float
        + {abstract} getStats() : Stats
        + {abstract} getVisualKey() : const std::string&
        + {abstract} getRemainingDuration() : float
    }

    class PlayerCombatStateMachine {
        - baseState : PlayerForm*
        - activeState : PlayerCombatState*
        - ownedTemporaryState : std::unique_ptr<PlayerCombatState>
        + setBaseState(form : PlayerForm*, player : Player&) : void
        + enterTemporaryState(state : std::unique_ptr<PlayerCombatState>, player : Player&) : void
        + update(player : Player&, dt : float) : void
        + revertToBaseState(player : Player&) : void
        + getActiveState() : PlayerCombatState*
        + isInTemporaryState() : bool
    }
    PlayerCombatStateMachine o-- PlayerCombatState

    abstract class PlayerForm << Strategy, State >> {
        # formType : FormType
        # formName : std::string
        # baseStats : Stats
        + attack(player : Player&, targetDir : sf::Vector2f, chamber : Chamber&) : void
        + {abstract} createSpecialState(abilityIndex : int) : std::unique_ptr<SpecialAbilityState>
        + onEnter(player : Player&) : void
        + onExit(player : Player&) : void
        + update(player : Player&, dt : float) : void
        + modifyOutgoingDamage(baseAmount : float) : float
        + modifyIncomingDamage(player : Player&, amount : float) : float
        + getStats() : Stats
        + getVisualKey() : const std::string&
        + getRemainingDuration() : float
        + getFormName() : const std::string&
    }
    PlayerForm ..|> PlayerCombatState

    class WraithbladeForm extends PlayerForm
    class VoidcasterForm extends PlayerForm
    class IronshellForm extends PlayerForm

    abstract class SpecialAbilityState << State, Decorator >> {
        # innerState : PlayerCombatState*
        # duration : float
        # elapsedTime : float
        + SpecialAbilityState(inner : PlayerCombatState*, duration : float)
        + onEnter(player : Player&) : void
        + onExit(player : Player&) : void
        + update(player : Player&, dt : float) : void
        + onAttack(player : Player&, targetDir : sf::Vector2f, chamber : Chamber&) : void
        + modifyOutgoingDamage(baseAmount : float) : float
        + modifyIncomingDamage(player : Player&, amount : float) : float
        + getStats() : Stats
        + getRemainingDuration() : float
        + {abstract} getStatModifier() : StatModifier
        + {abstract} getVisualKey() : const std::string&
    }
    SpecialAbilityState ..|> PlayerCombatState
    SpecialAbilityState o-- PlayerCombatState : delegates to inner

    ' ---- Concrete Special Ability Decorators ----
    
    ' Wraithblade Specials
    class WraithbladeRiftcrushState extends SpecialAbilityState
    class WraithbladeCinderveilState extends SpecialAbilityState

    ' Voidcaster Specials
    class VoidcasterLanceState extends SpecialAbilityState
    class VoidcasterDetonationFieldState extends SpecialAbilityState

    ' Ironshell Specials
    class IronshellAegisPulseState extends SpecialAbilityState
    class IronshellVeilOfThornsState extends SpecialAbilityState

    class Player extends Character {
        - character : PlayableCharacter*
        - forms : std::map<FormType, std::unique_ptr<PlayerForm>>
        - activeForm : PlayerForm*
        - formMomentum : std::map<FormType, float>
        - stateMachine : PlayerCombatStateMachine
        + Player(character : PlayableCharacter&)
        + switchForm(newForm : FormType) : void
        + gainMomentum(amount : float, form : FormType) : void
        + triggerSpecial(abilityIndex : int, chamber : Chamber&) : void
        + attack(targetDir : sf::Vector2f, chamber : Chamber&) : void
        + update(dt : float) : void
        + takeDamage(rawAmount : float) : void
        + getCharacter() : const PlayableCharacter&
    }

    abstract class PlayableCharacter << (A,#FF7F24) Abstract Factory >> {
        # name : std::string
        # description : std::string
        + {abstract} createForm1() : std::unique_ptr<PlayerForm>
        + {abstract} createForm2() : std::unique_ptr<PlayerForm>
        + {abstract} createForm3() : std::unique_ptr<PlayerForm>
        + getName() : const std::string&
        + getDescription() : const std::string&
    }

    class Serin extends PlayableCharacter {
        + createForm1() : std::unique_ptr<PlayerForm>
        + createForm2() : std::unique_ptr<PlayerForm>
        + createForm3() : std::unique_ptr<PlayerForm>
    }

    Player *-- PlayerCombatStateMachine
    Player o-- PlayerForm
    Player o-- PlayableCharacter
    PlayableCharacter ..> PlayerForm : creates

    ' ---- Enemy AI & Behaviors ----
    abstract class EnemyState << State >> {
        + {abstract} onEnter(enemy : Enemy&) : void
        + {abstract} onExit(enemy : Enemy&) : void
        + {abstract} update(enemy : Enemy&, dt : float, chamber : Chamber&) : void
    }

    class IdleState extends EnemyState
    class ChasingState extends EnemyState
    class AttackingState extends EnemyState
    class StaggeredState extends EnemyState

    abstract class EnemySteeringStrategy << Strategy >> {
        + {abstract} calculateSteering(enemy : Enemy&, player : const Player&, chamber : const Chamber&) : sf::Vector2f
    }
    class SeekStrategy extends EnemySteeringStrategy
    class EvadeStrategy extends EnemySteeringStrategy

    abstract class Enemy extends Character {
        # playerRef : Player&
        # currentState : EnemyState*
        # steeringStrategy : std::unique_ptr<EnemySteeringStrategy>
        # attackCooldown : float
        + changeState(newState : EnemyState*) : void
        + setSteeringStrategy(strategy : std::unique_ptr<EnemySteeringStrategy>) : void
        + getSteeringStrategy() : EnemySteeringStrategy*
        + updateState(dt : float, chamber : Chamber&) : void
    }
    Enemy *-- EnemyState
    Enemy *-- EnemySteeringStrategy

    class WaterloggedScribe extends Enemy
    class BoneSprinter extends Enemy {
        - isCarrier : bool
    }
    class ShardSoldier extends Enemy
    class SiegeWraith extends Enemy {
        + explode() : void
    }
    class ChoirHusk extends Enemy
    class ResonantCantor extends Enemy
    class HushedStalker extends Enemy {
        - isVisible : bool
    }
    class MirrorBearer extends Enemy {
        - isReal : bool
    }
    class VoidShunter extends Enemy
    class SarcophagusWarden extends Enemy
    class ShardWraith extends Enemy
    class BossMalachar extends Enemy {
        - currentPhase : int
        + transitionPhase(phase : int) : void
        + platformSunder(chamber : Chamber&) : void
        + soulLance(chamber : Chamber&) : void
    }

    class EnemyFactory {
        + {static} createEnemy(type : EnemyType, player : Player&) : std::unique_ptr<Enemy>
    }

    EnemyFactory ..> Enemy
}

' ============================================================
' PACKAGE: Chambers
' ============================================================
package "Chambers" {

    abstract class Chamber {
        # player : Player&
        # enemies : std::vector<std::unique_ptr<Enemy>>
        # items : std::vector<std::unique_ptr<Item>>
        # isCompleted : bool
        + {abstract} update(dt : float) : void
        + {abstract} draw(window : sf::RenderWindow&) : void
        + spawnEnemy(enemy : std::unique_ptr<Enemy>) : void
        + checkCollisions() : void
    }

    class ProtectChamber extends Chamber {
        - echo : std::unique_ptr<Echo>
        - requiredTime : float
    }
    class PreventChamber extends Chamber {
        - exitGate : sf::FloatRect
        - carriersEscaped : int
    }
    class GauntletChamber extends Chamber {
        - waves : std::vector<std::vector<EnemyType>>
        - currentWaveIndex : int
    }
    class MidChamber extends Chamber
    class BossChamber extends Chamber {
        - boss : std::unique_ptr<BossMalachar>
    }

    class ChamberFactory {
        + {static} createChamber(level : int, chamberIndex : int, player : Player&) : std::unique_ptr<Chamber>
    }

    class RenderableTileMap << Drawable >> {
        - vertices : sf::VertexArray
        - texture : const sf::Texture*
        + load(texture : const sf::Texture*, tileIds : const std::vector<std::vector<int> >&, cellSize : float) : void
        - draw(target : sf::RenderTarget&, states : sf::RenderStates) : void
    }

    class TileMapGenerator {
        + {static} generate(semanticGrid : const std::vector<std::vector<int> >&, cellSize : float, offsetX : float, offsetY : float) : RenderableTileMap
    }

    ChamberFactory ..> Chamber
    Chamber *-- Player
    Chamber *-- Enemy
    Chamber *-- Item
    Chamber *-- RenderableTileMap
    TileMapGenerator ..> RenderableTileMap : creates
}

' ============================================================
' PACKAGE: Economy
' ============================================================
package "Economy" {

    abstract class Item {
        # position : sf::Vector2f
        # bounds : sf::FloatRect
        + {abstract} onCollect(player : Player&, chamber : Chamber&) : void
    }

    class EchoFragment extends Item {
        - value : float
    }

    abstract class Echo << Subject >> {
        # name : std::string
        # echoPower : float
        # observers : std::vector<EchoObserver*>
        + takeDamage(penalty : float) : void
        + addPower(amount : float) : void
        + getPower() : float
        + attach(observer : EchoObserver*) : void
        + notify() : void
    }

    class ClarityShard extends Echo
    class MarrowEcho extends Echo
    class HollowBell extends Echo
    class ResonanceCore extends Echo
    class ObsidianKey extends Echo

    interface EchoObserver {
        + {abstract} onEchoPowerChanged(power : float) : void
    }

    Echo o-- EchoObserver
    GameplayState ..|> EchoObserver
}

@enduml
