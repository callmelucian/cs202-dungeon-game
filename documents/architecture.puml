@startuml Echoes_of_the_Ashen_Vault_Architecture

' --- Configuration ---
skinparam class {
    BackgroundColor White
    ArrowColor DeepSkyBlue
    BorderColor DarkSlateGray
}
skinparam stereotypeCBackgroundColor LightGreen
skinparam packageStyle rectangle

' ============================================================
' PACKAGE: Core Game Loop & State Management
' ============================================================
package "Core" {

    class Game << (S,#FF7F24) Singleton >> {
        - renderWindow : sf::RenderWindow
        - stateManager : StateManager
        - Game()
        + {static} getInstance() : Game&
        + runMainLoop() : void
        + getWindow() : sf::RenderWindow&
    }

    class StateManager {
        - states : std::stack<std::unique_ptr<GameState>>
        + pushState(state : std::unique_ptr<GameState>) : void
        + popState() : void
        + changeState(state : std::unique_ptr<GameState>) : void
        + update(dt : float) : void
        + draw() : void
        + handleEvents(event : sf::Event&) : void
    }

    abstract class GameState {
        # stateManager : StateManager&
        + {abstract} update(dt : float) : void
        + {abstract} draw(window : sf::RenderWindow&) : void
        + {abstract} handleEvents(event : sf::Event&) : void
    }

    class MainMenuState extends GameState
    class GameplayState extends GameState
    class PauseState extends GameState
    class GameOverState extends GameState
    class SettingState extends GameState
    class VictoryState extends GameState

    Game o-- StateManager
    StateManager *-- GameState
}

' ============================================================
' PACKAGE: Global Settings
' ============================================================
package "Global Settings" {

    class SettingManager << (S,#FF7F24) Singleton >> {
        - musicVolume : float
        - sfxVolume : float
        - difficulty : std::string
        - keyBindings : std::unordered_map<std::string, sf::Keyboard::Scancode>
        - SettingManager()
        + {static} getInstance() : SettingManager&
        + loadSettings(filepath : std::string) : bool
        + saveSettings(filepath : std::string) : bool
        + getMusicVolume() : float
        + setMusicVolume(volume : float) : void
        + getSfxVolume() : float
        + setSfxVolume(volume : float) : void
        + getDifficulty() : std::string
        + setDifficulty(diff : std::string) : void
        + getKeyBinding(action : std::string) : sf::Keyboard::Scancode
        + setKeyBinding(action : std::string, scancode : sf::Keyboard::Scancode) : void
    }

    class AssetManager << (S,#FF7F24) Singleton >> {
        - textures : std::unordered_map<std::string, sf::Texture>
        - fonts : std::unordered_map<std::string, sf::Font>
        - AssetManager()
        + {static} getInstance() : AssetManager&
        + loadTexture(name : std::string, filepath : std::string) : bool
        + getTexture(name : std::string) : const sf::Texture&
        + loadFont(name : std::string, filepath : std::string) : bool
        + getFont(name : std::string) : const sf::Font&
    }

    class SoundManager << (S,#FF7F24) Singleton >> {
        - soundBuffers : std::unordered_map<std::string, sf::SoundBuffer>
        - music : sf::Music
        - SoundManager()
        + {static} getInstance() : SoundManager&
        + loadSound(name : std::string, filepath : std::string) : bool
        + playSound(name : std::string) : void
        + playMusic(filepath : std::string, loop : bool) : void
        + stopMusic() : void
    }

    class SaveLoadManager << (S,#FF7F24) Singleton >> {
        - SaveLoadManager()
        + {static} getInstance() : SaveLoadManager&
        + saveGame(filepath : std::string, player : const Player&, levelNum : int, chamberNum : int, echoes : const std::vector<Echo*>&) : bool
        + loadGame(filepath : std::string, player : Player&, levelNum : int&, chamberNum : int&, echoes : std::vector<Echo*>&) : bool
    }

    class ColorPalette <<struct>> {
        + primary : sf::Color
        + secondary : sf::Color
        + background : sf::Color
        + text : sf::Color
        + accent : sf::Color
        + success : sf::Color
        + warning : sf::Color
        + disabled : sf::Color
    }

    interface ColorPaletteObserver {
        + {abstract} onColorPaletteChanged(newPalette : const ColorPalette&) : void
    }

    class ColorPaletteManager << (S,#FF7F24) Singleton >> {
        - currentPalette : ColorPalette
        - ColorPaletteManager()
        + {static} getInstance() : ColorPaletteManager&
        + getPalette() : const ColorPalette&
        + setPalette(palette : const ColorPalette&) : void
        + addObserver(observer : ColorPaletteObserver*) : void
        + removeObserver(observer : ColorPaletteObserver*) : void
    }

    ColorPaletteManager o-- ColorPaletteObserver
    ColorPaletteManager *-- ColorPalette
}

' ============================================================
' PACKAGE: UI Framework
' ============================================================
package "UI Framework" {

    abstract class Component << ColorPaletteObserver >> {
        # parent : Component*
        # position : sf::Vector2f
        # size : sf::Vector2f
        # modeX : SizeMode
        # modeY : SizeMode
        # fixedWidth : float
        # fixedHeight : float
        # marginTop : float
        # marginBottom : float
        # marginLeft : float
        # marginRight : float
        + {abstract} draw(target : sf::RenderTarget&) : void
        + {abstract} handleEvent(event : const sf::Event&) : void
        + {abstract} update(dt : float) : void
        + {abstract} onColorPaletteChanged(palette : const ColorPalette&) : void
        + {abstract} computeSize(availableSize : sf::Vector2f) : void
        + {abstract} setPosition(pos : sf::Vector2f) : void
    }

    class Text {
        - text : sf::Text
        - fontKey : std::string
        + Text(fontKey : std::string_view, characterSize : unsigned int)
        + setString(str : const sf::String&) : void
        + setCharacterSize(size : unsigned int) : void
        + setFillColor(color : const sf::Color&) : void
        + getUnderlyingText() : const sf::Text&
    }

    class Container {
        # children : std::vector<std::unique_ptr<Component>>
        # paddingTop : float
        # paddingBottom : float
        # paddingLeft : float
        # paddingRight : float
        # alignmentX : AlignmentX
        # alignmentY : AlignmentY
        # isRootNode : bool
        + addChild(child : std::unique_ptr<Component>) : Component*
        + createChild<T>(args...) : T*
        + getChildren() : const std::vector<std::unique_ptr<Component>>&
        + setPadding(top : float, bottom : float, left : float, right : float) : void
    }

    class FlexBox<Axis> {
        - spacing : float
        - distribution : Distribution
        - overflow : Overflow
    }

    class HorizontalBox << typedef >>
    class VerticalBox << typedef >>

    class Button {
        - state : ButtonState
        - label : std::unique_ptr<Text>
        - backgroundShape : sf::RectangleShape
        - onClickCallback : std::function<void()>
        - onPressedCallback : std::function<void()>
        + setOnClick(callback : std::function<void()>) : void
        + setOnPressed(callback : std::function<void()>) : void
        + setLabelText(labelText : const sf::String&) : void
    }

    class Slider {
        - minValue : float
        - maxValue : float
        - value : float
        - dragging : bool
        - dragOffset : float
        - trackShape : sf::RectangleShape
        - thumbShape : sf::RectangleShape
        - onValueChangedCallback : std::function<void(float)>
        + getValue() : float
        + setValue(newValue : float) : void
        + setOnValueChanged(callback : std::function<void(float)>) : void
    }

    class TextInput {
        - textDisplay : std::unique_ptr<Text>
        - backgroundShape : sf::RectangleShape
        - cursorShape : sf::RectangleShape
        - cursorIndex : std::uint32_t
        - hasFocus : bool
        - blinkTimer : float
        - blinkDuration : float
        - cursorVisible : bool
        - onTextChangedCallback : std::function<void(const sf::String&)>
        - onEnterPressedCallback : std::function<void()>
        + setTextString(str : const sf::String&) : void
        + getTextString() : sf::String
        + setKeyboardFocus(focus : bool) : void
    }

    Component ..|> ColorPaletteObserver
    Container --|> Component
    FlexBox --|> Container
    HorizontalBox --|> FlexBox
    VerticalBox --|> FlexBox
    Button --|> Component
    Slider --|> Component
    TextInput --|> Component
}

' ============================================================
' PACKAGE: Entities
' ============================================================
package "Entities" {

    abstract class Character {
        # position : sf::Vector2f
        # velocity : sf::Vector2f
        # hp : float
        # maxHp : float
        # baseDamage : float
        # moveSpeed : float
        # statusEffects : std::vector<std::unique_ptr<StatusEffect>>
        + {abstract} update(dt : float) : void
        + {abstract} draw(window : sf::RenderWindow&) : void
        + takeDamage(amount : float) : void
        + applyStatusEffect(effect : std::unique_ptr<StatusEffect>) : void
        + getPosition() : sf::Vector2f
        + getHp() : float
        + getSpeed() : float
        + setSpeed(speed : float) : void
    }

    abstract class StatusEffect {
        # duration : float
        # timer : float
        + {abstract} apply(character : Character&) : void
        + {abstract} remove(character : Character&) : void
        + update(dt : float, character : Character&) : bool
    }

    class BurnedEffect extends StatusEffect {
        - damagePerTick : float
    }
    class ParalyzedEffect extends StatusEffect {
        - missChance : float
    }
    class SlowedEffect extends StatusEffect {
        - speedReductionPercent : float
    }

    Character *-- StatusEffect

    class Player extends Character {
        - activeForm : std::unique_ptr<PlayerForm>
        - wraithbladeMomentum : float
        - voidcasterMomentum : float
        - ironshellMomentum : float
        + switchForm(newForm : FormType) : void
        + gainMomentum(amount : float, form : FormType) : void
        + triggerSpecial(abilityIndex : int, chamber : Chamber&) : void
    }

    abstract class PlayerForm << Strategy >> {
        # formType : FormType
        # baseSpeed : float
        # baseDamage : float
        + {abstract} attack(player : Player&, targetDir : sf::Vector2f, chamber : Chamber&) : void
        + {abstract} triggerSpecial1(player : Player&, chamber : Chamber&) : void
        + {abstract} triggerSpecial2(player : Player&, chamber : Chamber&) : void
        + getStats() : FormStats
    }

    class WraithbladeForm extends PlayerForm
    class VoidcasterForm extends PlayerForm
    class IronshellForm extends PlayerForm

    Player *-- PlayerForm
}

' ============================================================
' PACKAGE: Enemies
' ============================================================
package "Enemies" {

    abstract class Enemy extends Character {
        # playerRef : Player&
        # state : EnemyState
        # attackCooldown : float
        + {abstract} updateAI(dt : float, chamber : Chamber&) : void
    }

    class WaterloggedScribe extends Enemy
    class BoneSprinter extends Enemy {
        - isCarrier : bool
    }
    class ShardSoldier extends Enemy
    class SiegeWraith extends Enemy {
        + explode() : void
    }
    class ChoirHusk extends Enemy
    class ResonantCantor extends Enemy
    class HushedStalker extends Enemy {
        - isVisible : bool
    }
    class MirrorBearer extends Enemy {
        - isReal : bool
    }
    class VoidShunter extends Enemy
    class SarcophagusWarden extends Enemy

    class BossMalachar extends Enemy {
        - currentPhase : int
        + transitionPhase(phase : int) : void
        + platformSunder(chamber : Chamber&) : void
        + soulLance(chamber : Chamber&) : void
    }

    class EnemyFactory {
        + {static} createEnemy(type : EnemyType, player : Player&) : std::unique_ptr<Enemy>
    }

    EnemyFactory ..> Enemy
}

' ============================================================
' PACKAGE: Chambers
' ============================================================
package "Chambers" {

    abstract class Chamber {
        # player : Player&
        # enemies : std::vector<std::unique_ptr<Enemy>>
        # items : std::vector<std::unique_ptr<Item>>
        # isCompleted : bool
        + {abstract} update(dt : float) : void
        + {abstract} draw(window : sf::RenderWindow&) : void
        + spawnEnemy(enemy : std::unique_ptr<Enemy>) : void
        + checkCollisions() : void
    }

    class ProtectChamber extends Chamber {
        - echo : std::unique_ptr<Echo>
        - requiredTime : float
    }
    class PreventChamber extends Chamber {
        - exitGate : sf::FloatRect
        - carriersEscaped : int
    }
    class GauntletChamber extends Chamber {
        - waves : std::vector<std::vector<EnemyType>>
        - currentWaveIndex : int
    }
    class MidChamber extends Chamber
    class BossChamber extends Chamber {
        - boss : std::unique_ptr<BossMalachar>
    }

    class ChamberFactory {
        + {static} createChamber(level : int, chamberIndex : int, player : Player&) : std::unique_ptr<Chamber>
    }

    ChamberFactory ..> Chamber
    Chamber *-- Player
    Chamber *-- Enemy
    Chamber *-- Item
}

' ============================================================
' PACKAGE: Economy
' ============================================================
package "Economy" {

    abstract class Item {
        # position : sf::Vector2f
        # bounds : sf::FloatRect
        + {abstract} onCollect(player : Player&, chamber : Chamber&) : void
    }

    class EchoFragment extends Item {
        - value : float
    }

    abstract class Echo << Subject >> {
        # name : std::string
        # echoPower : float
        # observers : std::vector<EchoObserver*>
        + takeDamage(penalty : float) : void
        + addPower(amount : float) : void
        + getPower() : float
        + attach(observer : EchoObserver*) : void
        + notify() : void
    }

    class ClarityShard extends Echo
    class MarrowEcho extends Echo
    class HollowBell extends Echo
    class ResonanceCore extends Echo
    class ObsidianKey extends Echo

    interface EchoObserver {
        + {abstract} onEchoPowerChanged(power : float) : void
    }

    Echo o-- EchoObserver
    GameplayState ..|> EchoObserver
}

@enduml
